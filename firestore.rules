rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Regras para a coleção de logs de usuários
    match /user_logs/{logId} {
      
      // Função auxiliar para verificar se é o administrador
      function isAdmin() {
        return request.auth.token.email == 'joaomateus89@gmail.com';
      }

      // LEITURA:
      // - Admin: Pode ler tudo (para o Dashboard e Histórico).
      // - Usuário: Pode ler apenas seus próprios documentos (necessário para o script de heartbeat encontrar o doc para atualizar).
      allow read: if request.auth != null && (isAdmin() || resource.data.email == request.auth.token.email);

      // ESCRITA (Criar):
      // - Usuário pode criar um log, desde que o email gravado seja o dele mesmo.
      allow create: if request.auth != null && request.resource.data.email == request.auth.token.email;

      // ATUALIZAÇÃO:
      // - Usuário pode atualizar o timestamp (heartbeat), mas apenas nos seus próprios logs.
      // - Verifica também se o usuário não está tentando alterar o campo 'email' para se passar por outro.
      allow update: if request.auth != null 
                    && resource.data.email == request.auth.token.email
                    && request.resource.data.email == request.auth.token.email;
      
      // DELEÇÃO:
      // - Bloqueada para todos para manter o histórico íntegro.
      allow delete: if false;
    }
  }
}